#!/usr/bin/env bash

# Robust Git Extension: git-reset-changes
# Reverts local files (committed or uncommitted) and cleans untracked files to match a target branch.

set -uo pipefail

# Color formatting definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0;0m' # No Color

log_info() { echo -e "${BLUE}[info]${NC} $1"; }
log_success() { echo -e "${GREEN}[success]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[warn]${NC} $1"; }
log_error() { echo -e "${RED}[error]${NC} $1" >&2; }

show_help() {
    echo -e "${BOLD}Usage:${NC} git reset-changes [branch] [file1 file2 ...]"
    echo ""
    echo "An interactive TUI utility to safely reset file changes back to their state on a source branch."
    echo ""
    echo -e "${BOLD}Options:${NC}"
    echo "  -h, --help    Show this help message and exit"
    echo ""
    echo -e "${BOLD}Interactive Mode (No Arguments):${NC}"
    echo "  1. Prompts for a target source branch (fuzzy searchable via fzf)."
    echo "  2. Displays all files changed or untracked."
    echo "  3. Multi-select files using [Space] or [Tab]. Press [Enter] to confirm execution."
}

# 1. Guard Clauses & Validations
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    show_help
    exit 0
fi

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    log_error "Not a git repository (or any of the parent directories)."
    exit 1
fi

# 2. Resolve the Default Fallback Branch
DEFAULT_BRANCH="main"
if ! git rev-parse --verify main &>/dev/null; then
    if git rev-parse --verify master &>/dev/null; then
        DEFAULT_BRANCH="master"
    fi
fi

# 3. Determine Target Source Branch
SELECTED_BRANCH=""
if [[ $# -gt 0 ]]; then
    SELECTED_BRANCH="$1"
    shift # Consume branch argument
    
    if ! git rev-parse --verify "$SELECTED_BRANCH" &>/dev/null; then
        log_error "The specified branch '$SELECTED_BRANCH' does not exist."
        exit 1
    fi
else
    if ! command -v fzf &> /dev/null; then
        log_error "'fzf' is required for interactive mode but was not found."
        exit 1
    fi

    ALL_BRANCHES=$(git branch --format="%(refname:short)" | grep -v "^$DEFAULT_BRANCH$")
    BRANCH_MENU=$(printf "%s\n%s" "$DEFAULT_BRANCH" "$ALL_BRANCHES")
    
    SELECTED_BRANCH=$(echo "$BRANCH_MENU" | fzf \
        --header="Select target source branch to pull file states from:" \
        --reverse \
        --height=40% \
        --ansi)
    
    if [[ -z "$SELECTED_BRANCH" ]]; then
        log_warn "No branch selected. Operations cancelled."
        exit 0
    fi
fi

# 4. Determine File Array to Process
TRACKED_TO_RESTORE=()
UNTRACKED_TO_DELETE=()

if [[ $# -gt 0 ]]; then
    # CLI Mode: Explicit arguments passed
    for file in "$@"; do
        if git ls-files --error-unmatch "$file" &>/dev/null || git cat-file -e "${SELECTED_BRANCH}:${file}" &>/dev/null; then
            TRACKED_TO_RESTORE+=("$file")
        elif [[ -e "$file" ]]; then
            UNTRACKED_TO_DELETE+=("$file")
        else
            log_warn "File path '$file' does not exist locally or on ${SELECTED_BRANCH}. Skipping."
        fi
    done
else
    # TUI Mode: Gather tracked changes and untracked files separately
    TRACKED_CHANGES=$(git diff --name-only "$SELECTED_BRANCH" 2>/dev/null)
    UNTRACKED_FILES=$(git ls-files --others --exclude-standard)
    
    if [[ -z "$TRACKED_CHANGES" && -z "$UNTRACKED_FILES" ]]; then
        log_info "Your repository matches '${SELECTED_BRANCH}' perfectly. No files to reset."
        exit 0
    fi
    
    # Format the selection menu items with clear, colorized intent markers
    MENU_ITEMS=""
    if [[ -n "$TRACKED_CHANGES" ]]; then
        while IFS= read -r file; do
            [[ -n "$file" ]] && MENU_ITEMS+=$'\033[0;32m[Modified]\033[0m '"$file"$'\n'
        done <<< "$TRACKED_CHANGES"
    fi
    if [[ -n "$UNTRACKED_FILES" ]]; then
        while IFS= read -r file; do
            [[ -n "$file" ]] && MENU_ITEMS+=$'\033[0;31m[Untracked - WILL DELETE]\033[0m '"$file"$'\n'
        done <<< "$UNTRACKED_FILES"
    fi
    
    SELECTED_ITEMS=$(echo -e "$MENU_ITEMS" | sed '/^$/d' | fzf -m \
        --header="Select files to RESET (Space/Tab to select, Enter to execute):" \
        --reverse \
        --height=60% \
        --pointer="▶" \
        --marker="✓" \
        --ansi)
    
    if [[ -z "$SELECTED_ITEMS" ]]; then
        log_warn "No files selected. Operations cancelled."
        exit 0
    fi
    
    # Parse the fzf selections back into distinct arrays
    while IFS= read -r line; do
        if [[ "$line" == *"[Modified]"* ]]; then
            # Strip out the colorized prefix to get raw filename
            clean_file=$(echo "$line" | sed 's/^.*\[Modified\] //')
            TRACKED_TO_RESTORE+=("$clean_file")
        elif [[ "$line" == *"[Untracked - WILL DELETE]"* ]]; then
            clean_file=$(echo "$line" | sed 's/^.*\[Untracked - WILL DELETE\] //')
            UNTRACKED_TO_DELETE+=("$clean_file")
        fi
    done <<< "$SELECTED_ITEMS"
fi

# 5. Core Execution Engine
# Part A: Handle Tracked Files via Git Restore
if [[ ${#TRACKED_TO_RESTORE[@]} -gt 0 ]]; then
    log_info "Restoring ${#TRACKED_TO_RESTORE[@]} tracked file(s) to match '${SELECTED_BRANCH}'..."
    git restore --source="$SELECTED_BRANCH" --staged --worktree -- "${TRACKED_TO_RESTORE[@]}"
    for file in "${TRACKED_TO_RESTORE[@]}"; do
        log_success "Reverted: $file"
    done
fi

# Part B: Handle Untracked Files via File System Deletion
if [[ ${#UNTRACKED_TO_DELETE[@]} -gt 0 ]]; then
    log_warn "Deleting ${#UNTRACKED_TO_DELETE[@]} untracked file(s)/folder(s)..."
    rm -rf "${UNTRACKED_TO_DELETE[@]}"
    for file in "${UNTRACKED_TO_DELETE[@]}"; do
        log_success "Deleted: $file"
    done
fi

echo -e "\n${BOLD}Done!${NC} Workspace sync to '${SELECTED_BRANCH}' complete."